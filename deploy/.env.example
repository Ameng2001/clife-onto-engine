# 数智本体引擎·部署环境变量样例。复制为 deploy/.env 并按需改；勿把真实密钥提交进库。
# 用法：set -a; . deploy/.env; set +a; python scripts/serve.py 0.0.0.0 8000

# ---- 后端 / 本体 ----
ONTO_BACKEND=memory                 # memory | nebula
ONTO_ONTOLOGIES=grass,chili
# NEBULA_HOST=graphd
# NEBULA_PORT=9669

# ---- 数据来源（声明式租户接入；不设则 demo seed）----
ONTO_TENANTS=grass=tenants/mengcao/tenant.yaml

# ---- 访问控制（A 弧；不设即不启用）----
ONTO_AUTHZ=grass=deploy/authz.grass.yaml;chili=deploy/authz.chili.yaml
ONTO_TENANT_POLICY=deploy/tenant_policy.yaml
ONTO_IDENTITY=deploy/identity.yaml

# ---- LLM 凭据（或放 llm.local.json，勿提交）----
# DASHSCOPE_API_KEY=sk-xxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3.5-plus
